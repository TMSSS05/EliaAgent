# EliaDiscord Bot Environment Variables
# Copy this file to .env and fill in the values

# Required: Discord Bot Token
# Get from https://discord.com/developers/applications
# Or use your existing token from Discord Developer Portal
DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE

# Optional: OpenCode API Configuration (default: http://localhost:4096)
OPENCODE_HOST=http://localhost:4096
OPENCODE_API_KEY=

# Optional: Discord Server ID (for future features)
DISCORD_GUILD_ID=